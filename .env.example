# Copy this file to .env and fill in one provider.
# Do not commit .env.

# Option A: OpenAI-compatible AI Gateway /audio/transcriptions
VOICE_INPUT_STT_PROVIDER=gateway
AI_BASE_URL=https://staging.song-ai-api.com/v1
AI_API_KEY=
AI_STT_MODEL=whisper-1
AI_STT_LANGUAGE=zh

# Option B: Volcengine Doubao streaming ASR
# VOICE_INPUT_STT_PROVIDER=doubao
# DOUBAO_APP_ID=
# DOUBAO_ACCESS_KEY=
# DOUBAO_RESOURCE_ID=volc.bigasr.sauc.duration
# DOUBAO_ASR_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel

# Shared options
VOICE_INPUT_HISTORY_CONTEXT=1
VOICE_INPUT_PORT=8770
VOICE_INPUT_AUTO_PASTE=1
VOICE_INPUT_HOTKEY=<f2>
